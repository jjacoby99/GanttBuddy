[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace-with-a-random-secret"
expose_tokens = "id"

[auth.google_staging]
client_id = "replace-with-your-staging-streamlit-client-id"
client_secret = "replace-with-your-staging-streamlit-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[auth.google_prod]
client_id = "replace-with-your-production-streamlit-client-id"
client_secret = "replace-with-your-production-streamlit-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[ganttbuddy]
environment = "staging"

[ganttbuddy.environments.local]
api_base_url = "http://127.0.0.1:8000"
oidc_provider = "google_staging"

[ganttbuddy.environments.staging]
api_base_url = "https://ganttbuddy-api-staging-364477301326.us-west1.run.app"
oidc_provider = "google_staging"

[ganttbuddy.environments.production]
api_base_url = "https://ganttbuddy-api-production-469799823422.us-west1.run.app"
oidc_provider = "google_prod"
